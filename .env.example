# AI Search Checker Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://aicheck.ohmai.me
NEXT_PUBLIC_SITE_NAME="AI Search Checker"

# API Configuration
API_TIMEOUT_MS=30000
MAX_URL_LENGTH=2048

# Optional: External APIs
# GOOGLE_PAGESPEED_API_KEY=

# Required for AI Visibility Check
# Uses GPT-4.1 nano — cost ~$0.001 per check
OPENAI_API_KEY=

# Required for Google Presence scoring in AI Visibility
# Get free API key at https://serper.dev (2,500 free queries)
SERPER_API_KEY=

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
